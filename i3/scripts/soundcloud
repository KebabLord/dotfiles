#!/usr/bin/env bash

player="firefox"

[[ $(playerctl -p "$player" status 2>/dev/null) == "Playing" ]] || exit 0

url=$(playerctl -p "$player" metadata xesam:url 2>/dev/null)
[[ $url == https://soundcloud.com/* ]] || exit 0

title=$(playerctl -p "$player" metadata xesam:title 2>/dev/null)
artist=$(playerctl -p "$player" metadata xesam:artist 2>/dev/null)

title=$(sed -E 's/[[:space:]]*\([^)]*\)//g; s/^[[:space:]]+|[[:space:]]+$//g' <<< "$title")

if [[ $title == *" - "* ]]; then
    text="$title"
else
    text="$title"
    [[ -n $artist ]] && text+=" — $artist"
fi

text=${text:0:36}

text=${text//&/&amp;}
text=${text//</&lt;}
text=${text//>/&gt;}

printf '<span underline="low" underline_color="#FF5500">%s</span>\n' "$text"
